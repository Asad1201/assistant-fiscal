# Modele de configuration. Copie ce fichier en .env et renseigne tes vraies cles.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx

# Optionnel : si renseigne, l'interface web (app.py) demande ce mot de passe
# avant l'acces. A laisser vide en local ; a definir sur Streamlit Cloud (secrets)
# pour proteger la demo publique et eviter qu'un inconnu consomme la cle API.
APP_PASSWORD=
